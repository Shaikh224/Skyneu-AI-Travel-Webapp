# Skynfull environment variables
# Copy this file to .env for local development. Never commit real values.
#
# SECURITY NOTE:
# Every variable prefixed with VITE_ is exposed to browser users in the built app.
# Do not place private API keys, client secrets, admin keys, webhook secrets, or
# write-enabled tokens here. Put those in Appwrite Function/server environment
# variables and call them through a backend/proxy.

# Public Appwrite client configuration
VITE_APPWRITE_ENDPOINT=
VITE_APPWRITE_PROJECT_ID=
VITE_APPWRITE_DATABASE_ID=
VITE_APPWRITE_FUNCTION_ID=
VITE_APPWRITE_FUNCTION_PERPLEXITY_SEARCH=
VITE_APPWRITE_DODO_FUNCTION_ID=

# Appwrite collection IDs. These are identifiers, not secrets, but may reveal
# project structure. Leave blank in public examples unless needed for demos.
VITE_APPWRITE_USER_PREFERENCES_COLLECTION_ID=
VITE_APPWRITE_TRIPS_COLLECTION_ID=
VITE_APPWRITE_TRIP_MEMBERS_COLLECTION_ID=
VITE_APPWRITE_ACTIVITIES_COLLECTION_ID=
VITE_APPWRITE_CHECKLIST_COLLECTION_ID=
VITE_APPWRITE_EXPENSES_COLLECTION_ID=
VITE_APPWRITE_SAVED_FLIGHTS_COLLECTION_ID=
VITE_APPWRITE_SHARE_CARDS_COLLECTION_ID=
VITE_APPWRITE_NOTIFICATIONS_COLLECTION_ID=
VITE_APPWRITE_NOTIFICATION_PREFERENCES_COLLECTION_ID=

# Public Sanity read configuration. Do not use a Sanity token in the browser.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Backend/Appwrite Function URLs that keep private provider keys server-side.
VITE_FLIGHT_SEARCH_FUNCTION_URL=

# Browser-exposed provider keys used by existing client-side features.
# Restrict these keys by domain/referrer/provider dashboard, or move the calls
# behind a server/Appwrite Function before deploying publicly.
VITE_SONAR_API_KEY=
VITE_GEMINI_API_KEY=
VITE_UNSPLASH_ACCESS_KEY=
VITE_NEWS_API_KEY=
VITE_FR24_API_KEY=
VITE_AVIATIONSTACK_API_KEY=
VITE_AVIATION_EDGE_API_KEY=

# Server/function-only variables that must NOT be prefixed with VITE_:
# AMADEUS_CLIENT_ID=
# AMADEUS_CLIENT_SECRET=
# PERPLEXITY_API_KEY=
# SONAR_PRO_API_KEY=
# GEMINI_API_KEY=
# DODO_PAYMENTS_API_KEY=
# DODO_PAYMENTS_WEBHOOK_SECRET=
